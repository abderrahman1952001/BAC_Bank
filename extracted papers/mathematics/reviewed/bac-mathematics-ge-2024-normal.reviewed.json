          "blocks": [
            {
              "id": "s1_e2_prompt",
              "role": "PROMPT",
              "type": "paragraph",
              "value": "عين الاقتراح الصحيح الوحيد من بين الاقتراحات الثلاثة في كل حالة من الحالات الآتية مع التبرير."
            }
          ]
        },
        {
          "id": "s1_e2_q1",
          "nodeType": "QUESTION",
