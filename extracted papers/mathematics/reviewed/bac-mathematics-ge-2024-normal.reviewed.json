            {
              "id": "s1_e3_q1_rubric",
              "role": "RUBRIC",
              "type": "paragraph",
              "value": "1 نقطة."
            }
          ]
        },
        {
          "id": "s1_e3_q2",
          "nodeType": "QUESTION",
          "parentId": "s1_e3",
          "orderIndex": 2,
          "label": "السؤال 2",
          "maxPoints": 1,
          "topicCodes": [],
          "blocks": [
            {
              "id": "s1_e3_q2_prompt",
              "role": "PROMPT",
              "type": "paragraph",
              "value": "برر أن $A$ نقطة انعطاف لـ$(C_f)$."
            },
            {
              "id": "s1_e3_q2_solution",
              "role": "SOLUTION",
              "type": "paragraph",
              "value": "من الوضع النسبي لـ$(C_f)$ والمماس $(T)$، تكون النقطة $A$ نقطة انعطاف لـ$(C_f)$."
            },
            {
              "id": "s1_e3_q2_rubric",
              "role": "RUBRIC",
              "type": "paragraph",
