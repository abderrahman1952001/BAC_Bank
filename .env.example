# API
PORT=3001
NODE_ENV=development
PUBLIC_API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
TRUST_PROXY=false
LOG_HTTP_REQUESTS=true
HEALTH_WORKER_STALE_MS=45000
HEALTH_REQUIRE_WORKER=true

# Database
DATABASE_URL=postgresql://bac_user:bac_password@localhost:5433/bac_bank?schema=public
PRISMA_CONNECT_ON_STARTUP=true

# Redis
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false

# Auth
AUTH_SESSION_SECRET=replace_with_a_random_secret_at_least_32_chars
AUTH_SESSION_TTL_DAYS=7
AUTH_ADMIN_SESSION_TTL_HOURS=12
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX_PER_IP=20
AUTH_LOGIN_RATE_LIMIT_MAX_PER_EMAIL=8
AUTH_REGISTER_RATE_LIMIT_MAX_PER_IP=10
AUTH_REGISTER_RATE_LIMIT_MAX_PER_EMAIL=4
JWT_ACCESS_SECRET=replace_with_a_random_secret_at_least_32_chars
AUTH_BOOTSTRAP_ADMIN_EMAIL=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_USERNAME=BAC Admin
AUTH_BOOTSTRAP_ADMIN_STREAM_CODE=SE
AUTH_BOOTSTRAP_ADMIN_ON_STARTUP=false

# QBank
SESSION_YEAR_MAX=

# Ingestion / R2
INGESTION_MIN_YEAR=2008
INGESTION_QUEUE_POLL_INTERVAL_MS=5000
INGESTION_PROCESSING_LEASE_MS=1800000
WORKER_HEARTBEAT_INTERVAL_MS=10000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MAX_OUTPUT_TOKENS=65535
GEMINI_TEMPERATURE=1
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ENDPOINT=

# Web app
NEXT_PUBLIC_API_BASE_URL=/api/v1
API_UPSTREAM_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_ASSET_BASE_URL=
