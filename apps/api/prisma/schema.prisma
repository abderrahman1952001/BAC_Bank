generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionType {
  NORMAL
  MAKEUP
}

enum PracticeSessionStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum IngestionJobStatus {
  DRAFT
  QUEUED
  PROCESSING
  IN_REVIEW
  APPROVED
  PUBLISHED
  FAILED
}

enum SourceDocumentKind {
  EXAM
  CORRECTION
}

enum ExamVariantCode {
  SUJET_1
  SUJET_2
}

enum ExamNodeType {
  EXERCISE
  PART
  QUESTION
  SUBQUESTION
  CONTEXT
}

enum BlockRole {
  STEM
  PROMPT
  SOLUTION
  HINT
  RUBRIC
  META
}

enum BlockType {
  PARAGRAPH
  LATEX
  IMAGE
  CODE
  HEADING
  LIST
  TABLE
  GRAPH
  TREE
}

enum MediaType {
  IMAGE
  FILE
}

enum UserRole {
  USER
  ADMIN
  REVIEWER
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

model StreamFamily {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  slug        String?  @unique
  description String?  @db.Text
  pathways    Stream[]
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("stream_families")
}

model Stream {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  familyId            String              @map("family_id") @db.Uuid
  code                String              @unique
  name                String
  slug                String?             @unique
  description         String?             @db.Text
  isDefault           Boolean             @default(false) @map("is_default")
  family              StreamFamily        @relation(fields: [familyId], references: [id], onDelete: Restrict)
  subjectMappings     StreamSubject[]
  exams               Exam[]
  paperSourceMappings PaperSourceStream[]
  users               User[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([familyId])
  @@index([familyId, isDefault])
  @@map("streams")
}

model SubjectFamily {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique
  name        String
  slug        String?   @unique
  description String?   @db.Text
  subjects    Subject[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("subject_families")
}

model Subject {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  familyId       String          @map("family_id") @db.Uuid
  code           String          @unique
  name           String
  slug           String?         @unique
  description    String?         @db.Text
  isDefault      Boolean         @default(false) @map("is_default")
  family         SubjectFamily   @relation(fields: [familyId], references: [id], onDelete: Restrict)
  streamMappings StreamSubject[]
  exams          Exam[]          @relation("SubjectExams")
  papers         Paper[]         @relation("SubjectPapers")
  paperSources   PaperSource[]
  topics         Topic[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([familyId])
  @@index([familyId, isDefault])
  @@map("subjects")
}

model StreamSubject {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  streamId      String   @map("stream_id") @db.Uuid
  subjectId     String   @map("subject_id") @db.Uuid
  coefficient   Int?
  isOptional    Boolean  @default(false) @map("is_optional")
  validFromYear Int      @default(0) @map("valid_from_year")
  validToYear   Int?     @map("valid_to_year")
  createdAt     DateTime @default(now()) @map("created_at")
  stream        Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([streamId, subjectId, validFromYear])
  @@index([subjectId])
  @@index([streamId, validFromYear, validToYear])
  @@map("stream_subjects")
}

model PaperSource {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                    String              @unique
  provider                String
  year                    Int
  sessionType             SessionType         @map("session_type")
  subjectId               String              @map("subject_id") @db.Uuid
  familyCode              String              @map("family_code")
  sourceListingUrl        String?             @map("source_listing_url") @db.Text
  sourceExamPageUrl       String?             @map("source_exam_page_url") @db.Text
  sourceCorrectionPageUrl String?             @map("source_correction_page_url") @db.Text
  metadata                Json?
  subject                 Subject             @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  streamMappings          PaperSourceStream[]
  sourceDocuments         SourceDocument[]
  ingestionJobs           IngestionJob[]
  papers                  Paper[]
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  @@unique([year, subjectId, sessionType, familyCode])
  @@index([subjectId])
  @@index([year, subjectId, sessionType])
  @@map("paper_sources")
}

model PaperSourceStream {
  paperSourceId String      @map("paper_source_id") @db.Uuid
  streamId      String      @map("stream_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  paperSource   PaperSource @relation(fields: [paperSourceId], references: [id], onDelete: Cascade)
  stream        Stream      @relation(fields: [streamId], references: [id], onDelete: Restrict)

  @@id([paperSourceId, streamId])
  @@index([streamId])
  @@map("paper_source_streams")
}

model Paper {
  id                      String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperSourceId           String         @unique @map("paper_source_id") @db.Uuid
  year                    Int
  subjectId               String         @map("subject_id") @db.Uuid
  sessionType             SessionType    @map("session_type")
  familyCode              String         @map("family_code")
  durationMinutes         Int            @map("duration_minutes")
  officialSourceReference String?        @map("official_source_reference") @db.Text
  paperSource             PaperSource    @relation(fields: [paperSourceId], references: [id], onDelete: Restrict)
  subject                 Subject        @relation("SubjectPapers", fields: [subjectId], references: [id], onDelete: Restrict)
  offerings               Exam[]
  variants                ExamVariant[]
  ingestionJobs           IngestionJob[] @relation("IngestionJobPublishedPaper")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  @@unique([year, subjectId, sessionType, familyCode])
  @@index([year, subjectId, sessionType])
  @@map("papers")
}

model Exam {
  id               String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year             Int
  streamId         String                    @map("stream_id") @db.Uuid
  subjectId        String                    @map("subject_id") @db.Uuid
  sessionType      SessionType               @map("session_type")
  paperId          String                    @map("paper_id") @db.Uuid
  isPublished      Boolean                   @default(false) @map("is_published")
  stream           Stream                    @relation(fields: [streamId], references: [id], onDelete: Restrict)
  subject          Subject                   @relation("SubjectExams", fields: [subjectId], references: [id], onDelete: Restrict)
  paper            Paper                     @relation(fields: [paperId], references: [id], onDelete: Restrict)
  ingestionJobs    IngestionJob[]            @relation("IngestionJobPublishedExam")
  sessionExercises PracticeSessionExercise[]
  activities       ExamActivity[]
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  @@unique([year, streamId, subjectId, sessionType])
  @@index([year, streamId, subjectId])
  @@index([paperId])
  @@map("exams")
}

model ExamVariant {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperId   String            @map("paper_id") @db.Uuid
  code      ExamVariantCode
  title     String?
  status    PublicationStatus @default(DRAFT)
  metadata  Json?
  paper     Paper             @relation(fields: [paperId], references: [id], onDelete: Cascade)
  nodes     ExamNode[]
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([paperId, code])
  @@index([paperId, status])
  @@map("exam_variants")
}

model ExamNode {
  id               String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId        String                    @map("variant_id") @db.Uuid
  parentId         String?                   @map("parent_id") @db.Uuid
  nodeType         ExamNodeType              @map("node_type")
  orderIndex       Int                       @map("order_index")
  label            String?
  maxPoints        Decimal?                  @map("max_points") @db.Decimal(6, 2)
  status           PublicationStatus         @default(DRAFT)
  metadata         Json?
  variant          ExamVariant               @relation(fields: [variantId], references: [id], onDelete: Cascade)
  parent           ExamNode?                 @relation("ExamNodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children         ExamNode[]                @relation("ExamNodeHierarchy")
  blocks           ExamNodeBlock[]
  topicMappings    ExamNodeTopic[]
  sessionExercises PracticeSessionExercise[]
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  @@unique([variantId, parentId, orderIndex])
  @@index([variantId, nodeType])
  @@index([parentId])
  @@map("exam_nodes")
}

model ExamNodeBlock {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId     String    @map("node_id") @db.Uuid
  role       BlockRole
  orderIndex Int       @map("order_index")
  blockType  BlockType @map("block_type")
  textValue  String?   @map("text_value") @db.Text
  mediaId    String?   @map("media_id") @db.Uuid
  data       Json?
  node       ExamNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  media      Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([nodeId, role, orderIndex])
  @@index([nodeId, role])
  @@index([mediaId])
  @@map("exam_node_blocks")
}

model Topic {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId      String           @map("subject_id") @db.Uuid
  code           String
  name           String
  slug           String
  parentId       String?          @map("parent_id") @db.Uuid
  displayOrder   Int              @default(0) @map("display_order")
  isSelectable   Boolean          @default(true) @map("is_selectable")
  studentLabel   String?          @map("student_label")
  subject        Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parent         Topic?           @relation("TopicHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Topic[]          @relation("TopicHierarchy")
  examNodeTopics ExamNodeTopic[]
  topicStats     UserTopicStats[]
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@unique([subjectId, code])
  @@unique([subjectId, slug])
  @@unique([subjectId, parentId, name])
  @@index([subjectId])
  @@index([subjectId, displayOrder])
  @@index([parentId])
  @@map("topics")
}

model ExamNodeTopic {
  nodeId  String   @map("node_id") @db.Uuid
  topicId String   @map("topic_id") @db.Uuid
  node    ExamNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  topic   Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([nodeId, topicId])
  @@index([topicId])
  @@map("exam_node_topics")
}

model User {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkUserId      String?           @unique @map("clerk_user_id")
  email            String            @unique
  fullName         String?           @map("full_name")
  passwordHash     String?           @map("password_hash")
  role             UserRole          @default(USER)
  subscriptionStatus SubscriptionStatus @default(FREE) @map("subscription_status")
  streamFamilyId   String?           @map("stream_family_id") @db.Uuid
  streamId         String?           @map("stream_id") @db.Uuid
  streamFamily     StreamFamily?     @relation(fields: [streamFamilyId], references: [id], onDelete: SetNull)
  stream           Stream?           @relation(fields: [streamId], references: [id], onDelete: SetNull)
  authSessions     AuthSession[]
  topicStats       UserTopicStats[]
  uploadedMedia    Media[]           @relation("UserUploadedMedia")
  practiceSessions PracticeSession[]
  examActivities   ExamActivity[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([streamFamilyId])
  @@index([streamId])
  @@map("users")
}

model AuthSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@index([userId, createdAt])
  @@index([userId, revokedAt])
  @@map("auth_sessions")
}

model Media {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url        String          @db.Text
  type       MediaType
  uploadedBy String?         @map("uploaded_by") @db.Uuid
  metadata   Json?
  uploader   User?           @relation("UserUploadedMedia", fields: [uploadedBy], references: [id], onDelete: SetNull)
  blocks     ExamNodeBlock[]
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@index([uploadedBy, createdAt])
  @@map("media")
}

model IngestionJob {
  id                       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperSourceId            String             @map("paper_source_id") @db.Uuid
  label                    String
  status                   IngestionJobStatus @default(DRAFT)
  reviewNotes              String?            @map("review_notes") @db.Text
  errorMessage             String?            @map("error_message") @db.Text
  processingRequestedAt    DateTime?          @map("processing_requested_at")
  processingStartedAt      DateTime?          @map("processing_started_at")
  processingFinishedAt     DateTime?          @map("processing_finished_at")
  processingLeaseExpiresAt DateTime?          @map("processing_lease_expires_at")
  processingWorkerId       String?            @map("processing_worker_id")
  processingAttemptCount   Int                @default(0) @map("processing_attempt_count")
  draftJson                Json               @map("draft_json")
  metadata                 Json?
  reviewedAt               DateTime?          @map("reviewed_at")
  publishedAt              DateTime?          @map("published_at")
  paperSource              PaperSource        @relation(fields: [paperSourceId], references: [id], onDelete: Cascade)
  publishedExamId          String?            @map("published_exam_id") @db.Uuid
  publishedPaperId         String?            @map("published_paper_id") @db.Uuid
  publishedExam            Exam?              @relation("IngestionJobPublishedExam", fields: [publishedExamId], references: [id], onDelete: SetNull)
  publishedPaper           Paper?             @relation("IngestionJobPublishedPaper", fields: [publishedPaperId], references: [id], onDelete: SetNull)
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")

  @@index([paperSourceId])
  @@index([status, createdAt])
  @@index([status, processingRequestedAt])
  @@index([processingLeaseExpiresAt])
  @@index([publishedExamId])
  @@index([publishedPaperId])
  @@map("ingestion_jobs")
}

model WorkerHeartbeat {
  workerId        String    @id @map("worker_id")
  workerType      String    @map("worker_type")
  lastHeartbeatAt DateTime  @map("last_heartbeat_at")
  startedAt       DateTime  @default(now()) @map("started_at")
  stoppedAt       DateTime? @map("stopped_at")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([workerType, lastHeartbeatAt])
  @@index([workerType, stoppedAt])
  @@map("worker_heartbeats")
}

model SourceDocument {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperSourceId String             @map("paper_source_id") @db.Uuid
  kind          SourceDocumentKind
  storageKey    String             @map("storage_key")
  fileName      String             @map("file_name")
  mimeType      String             @map("mime_type")
  pageCount     Int?               @map("page_count")
  sha256        String?
  sourceUrl     String?            @map("source_url") @db.Text
  language      String?
  metadata      Json?
  paperSource   PaperSource        @relation(fields: [paperSourceId], references: [id], onDelete: Cascade)
  pages         SourcePage[]
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@unique([paperSourceId, kind])
  @@index([paperSourceId])
  @@map("source_documents")
}

model SourcePage {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String         @map("document_id") @db.Uuid
  pageNumber Int            @map("page_number")
  storageKey String         @map("storage_key")
  width      Int
  height     Int
  sha256     String?
  metadata   Json?
  document   SourceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@unique([documentId, pageNumber])
  @@index([documentId])
  @@map("source_pages")
}

model UserTopicStats {
  userId             String   @map("user_id") @db.Uuid
  topicId            String   @map("topic_id") @db.Uuid
  accuracyPercentage Decimal  @default(0) @map("accuracy_percentage") @db.Decimal(5, 2)
  totalAttempts      Int      @default(0) @map("total_attempts")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic              Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
  @@index([topicId])
  @@map("user_topic_stats")
}

model ExamActivity {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  examId                 String   @map("exam_id") @db.Uuid
  sujetNumber            Int      @map("sujet_number")
  totalQuestionCount     Int      @default(0) @map("total_question_count")
  completedQuestionCount Int      @default(0) @map("completed_question_count")
  openedQuestionCount    Int      @default(0) @map("opened_question_count")
  solutionViewedCount    Int      @default(0) @map("solution_viewed_count")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam                   Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now()) @map("created_at")
  lastOpenedAt           DateTime @default(now()) @map("last_opened_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([userId, examId, sujetNumber])
  @@index([examId])
  @@index([userId, lastOpenedAt])
  @@map("exam_activities")
}

model PracticeSession {
  id                     String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String?                   @map("user_id") @db.Uuid
  title                  String?
  requestedExerciseCount Int                       @default(6) @map("requested_exercise_count")
  filtersJson            Json?                     @map("filters_json")
  progressJson           Json?                     @map("progress_json")
  status                 PracticeSessionStatus     @default(CREATED)
  user                   User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises              PracticeSessionExercise[]
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("practice_sessions")
}

model PracticeSessionExercise {
  sessionId      String          @map("session_id") @db.Uuid
  exerciseNodeId String          @map("exercise_node_id") @db.Uuid
  examId         String?         @map("exam_id") @db.Uuid
  orderIndex     Int             @map("order_index")
  session        PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseNode   ExamNode        @relation(fields: [exerciseNodeId], references: [id], onDelete: Cascade)
  exam           Exam?           @relation(fields: [examId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now()) @map("created_at")

  @@id([sessionId, exerciseNodeId])
  @@unique([sessionId, orderIndex])
  @@index([exerciseNodeId])
  @@index([examId])
  @@map("practice_session_exercises")
}
