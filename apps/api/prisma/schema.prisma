generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionType {
  NORMAL
  MAKEUP
}

enum ContentFormat {
  MARKDOWN
  HYBRID
}

enum AssetType {
  IMAGE
  GRAPH
  TABLE
  FILE
}

enum PracticeSessionStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum ExamVariantCode {
  SUJET_1
  SUJET_2
}

enum ExamNodeType {
  EXERCISE
  PART
  QUESTION
  SUBQUESTION
  CONTEXT
}

enum BlockRole {
  STEM
  PROMPT
  SOLUTION
  HINT
  RUBRIC
  META
}

enum BlockType {
  PARAGRAPH
  LATEX
  IMAGE
  CODE
  HEADING
  LIST
  TABLE
}

enum MediaType {
  IMAGE
  FILE
}

enum UserRole {
  USER
  ADMIN
  REVIEWER
}

model Stream {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String          @unique
  name            String          @unique
  slug            String?         @unique
  description     String?         @db.Text
  subjectMappings StreamSubject[]
  exams           Exam[]
  users           User[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@map("streams")
}

model Subject {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String          @unique
  name           String          @unique
  slug           String?         @unique
  coefficient    Int?
  streamMappings StreamSubject[]
  exams          Exam[]          @relation("SubjectExams")
  topics         Topic[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@map("subjects")
}

model StreamSubject {
  streamId   String   @map("stream_id") @db.Uuid
  subjectId  String   @map("subject_id") @db.Uuid
  coefficient Int?
  createdAt  DateTime @default(now()) @map("created_at")
  stream     Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([streamId, subjectId])
  @@index([subjectId])
  @@map("stream_subjects")
}

model Exam {
  id                      String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year                    Int
  streamId                String      @map("stream_id") @db.Uuid
  subjectId               String      @map("subject_id") @db.Uuid
  sessionType             SessionType @map("session_type")
  durationMinutes         Int         @map("duration_minutes")
  totalPoints             Int         @map("total_points")
  officialSourceReference String?     @map("official_source_reference") @db.Text
  isPublished             Boolean     @default(false) @map("is_published")
  stream                  Stream      @relation(fields: [streamId], references: [id], onDelete: Restrict)
  subject                 Subject     @relation("SubjectExams", fields: [subjectId], references: [id], onDelete: Restrict)
  variants                ExamVariant[]
  exercises               Exercise[]
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")

  @@unique([year, streamId, subjectId, sessionType])
  @@index([year, streamId, subjectId])
  @@map("exams")
}

model ExamVariant {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId    String            @map("exam_id") @db.Uuid
  code      ExamVariantCode
  title     String?
  status    PublicationStatus @default(DRAFT)
  metadata  Json?
  exam      Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  nodes     ExamNode[]
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([examId, code])
  @@index([examId, status])
  @@map("exam_variants")
}

model ExamNode {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId String            @map("variant_id") @db.Uuid
  parentId  String?           @map("parent_id") @db.Uuid
  nodeType  ExamNodeType      @map("node_type")
  orderIndex Int              @map("order_index")
  label     String?
  title     String?
  maxPoints Decimal?          @map("max_points") @db.Decimal(6, 2)
  status    PublicationStatus @default(DRAFT)
  metadata  Json?
  variant   ExamVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  parent    ExamNode?         @relation("ExamNodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  ExamNode[]        @relation("ExamNodeHierarchy")
  blocks    ExamNodeBlock[]
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([variantId, parentId, orderIndex])
  @@index([variantId, nodeType])
  @@index([parentId])
  @@map("exam_nodes")
}

model ExamNodeBlock {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId     String    @map("node_id") @db.Uuid
  role       BlockRole
  orderIndex Int       @map("order_index")
  blockType  BlockType @map("block_type")
  textValue  String?   @map("text_value") @db.Text
  mediaId    String?   @map("media_id") @db.Uuid
  data       Json?
  node       ExamNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  media      Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([nodeId, role, orderIndex])
  @@index([nodeId, role])
  @@index([mediaId])
  @@map("exam_node_blocks")
}

model Exercise {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId      String     @map("exam_id") @db.Uuid
  title       String?
  introText   String?    @map("intro_text") @db.Text
  orderIndex  Int        @map("order_index")
  totalPoints Int        @map("total_points")
  exam        Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions   Question[]
  sessionExercises PracticeSessionExercise[]
  createdAt   DateTime   @default(now()) @map("created_at")

  @@unique([examId, orderIndex])
  @@index([examId])
  @@map("exercises")
}

model Question {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exerciseId      String            @map("exercise_id") @db.Uuid
  orderIndex      Int               @map("order_index")
  points          Int
  difficultyLevel Int?              @map("difficulty_level")
  contentFormat   ContentFormat     @default(MARKDOWN) @map("content_format")
  isActive        Boolean           @default(true) @map("is_active")
  exercise        Exercise          @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  contents        QuestionContent[]
  assets          QuestionAsset[]
  answer          Answer?
  questionTopics  QuestionTopic[]
  attempts        UserAttempt[]
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([exerciseId, orderIndex])
  @@index([exerciseId])
  @@map("questions")
}

model QuestionContent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId      String   @map("question_id") @db.Uuid
  contentMarkdown String   @map("content_markdown") @db.Text
  versionNumber   Int      @default(1) @map("version_number")
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([questionId, versionNumber])
  @@index([questionId, createdAt])
  @@map("question_contents")
}

model QuestionAsset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId String    @map("question_id") @db.Uuid
  fileUrl    String    @map("file_url") @db.Text
  assetType  AssetType @map("asset_type")
  orderIndex Int       @default(0) @map("order_index")
  caption    String?   @db.Text
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([questionId, orderIndex])
  @@map("question_assets")
}

model Answer {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questionId                String   @unique @map("question_id") @db.Uuid
  officialAnswerMarkdown    String   @map("official_answer_markdown") @db.Text
  markingSchemeMarkdown     String?  @map("marking_scheme_markdown") @db.Text
  commonMistakesMarkdown    String?  @map("common_mistakes_markdown") @db.Text
  examinerCommentaryMarkdown String? @map("examiner_commentary_markdown") @db.Text
  question                  Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("answers")
}

model Topic {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId      String          @map("subject_id") @db.Uuid
  code           String
  name           String
  parentId       String?         @map("parent_id") @db.Uuid
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parent         Topic?          @relation("TopicHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Topic[]         @relation("TopicHierarchy")
  questionTopics QuestionTopic[]
  topicStats     UserTopicStats[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([subjectId, code])
  @@unique([subjectId, parentId, name])
  @@index([subjectId])
  @@index([parentId])
  @@map("topics")
}

model QuestionTopic {
  questionId String  @map("question_id") @db.Uuid
  topicId    String  @map("topic_id") @db.Uuid
  weight     Decimal @default(1.0) @db.Decimal(4, 2)
  isPrimary  Boolean @default(false) @map("is_primary")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([questionId, topicId])
  @@index([topicId])
  @@map("question_topics")
}

model User {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String          @unique
  fullName     String?         @map("full_name")
  passwordHash String          @map("password_hash")
  role         UserRole        @default(USER)
  streamId     String?         @map("stream_id") @db.Uuid
  stream       Stream?         @relation(fields: [streamId], references: [id], onDelete: SetNull)
  attempts     UserAttempt[]
  topicStats   UserTopicStats[]
  uploadedMedia Media[]        @relation("UserUploadedMedia")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([streamId])
  @@map("users")
}

model Media {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url        String          @db.Text
  type       MediaType
  uploadedBy String?         @map("uploaded_by") @db.Uuid
  metadata   Json?
  uploader   User?           @relation("UserUploadedMedia", fields: [uploadedBy], references: [id], onDelete: SetNull)
  blocks     ExamNodeBlock[]
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  @@index([uploadedBy, createdAt])
  @@map("media")
}

model UserAttempt {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  questionId      String   @map("question_id") @db.Uuid
  selectedAnswer  String?  @map("selected_answer") @db.Text
  isCorrect       Boolean? @map("is_correct")
  scoreAwarded    Decimal? @map("score_awarded") @db.Decimal(5, 2)
  maxScore        Decimal? @map("max_score") @db.Decimal(5, 2)
  timeSpentSeconds Int?    @map("time_spent_seconds")
  attemptedAt     DateTime @default(now()) @map("attempted_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, questionId])
  @@index([questionId, attemptedAt])
  @@map("user_attempts")
}

model UserTopicStats {
  userId             String   @map("user_id") @db.Uuid
  topicId            String   @map("topic_id") @db.Uuid
  accuracyPercentage Decimal  @default(0) @map("accuracy_percentage") @db.Decimal(5, 2)
  totalAttempts      Int      @default(0) @map("total_attempts")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic              Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([userId, topicId])
  @@index([topicId])
  @@map("user_topic_stats")
}

model PracticeSession {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                String?
  requestedExerciseCount Int                     @default(6) @map("requested_exercise_count")
  filtersJson          Json?                     @map("filters_json")
  status               PracticeSessionStatus     @default(CREATED)
  exercises            PracticeSessionExercise[]
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("practice_sessions")
}

model PracticeSessionExercise {
  sessionId   String          @map("session_id") @db.Uuid
  exerciseId  String          @map("exercise_id") @db.Uuid
  orderIndex  Int             @map("order_index")
  session     PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise    Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now()) @map("created_at")

  @@id([sessionId, exerciseId])
  @@unique([sessionId, orderIndex])
  @@index([exerciseId])
  @@map("practice_session_exercises")
}
