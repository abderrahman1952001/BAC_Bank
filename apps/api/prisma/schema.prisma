generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionType {
  NORMAL
  MAKEUP
}

enum StudySessionStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum StudySessionFamily {
  DRILL
  SIMULATION
}

enum StudySessionKind {
  TOPIC_DRILL
  MIXED_DRILL
  WEAK_POINT_DRILL
  PAPER_SIMULATION
}

enum StudySessionResumeMode {
  SOLVE
  REVIEW
}

enum StudyQuestionAnswerState {
  UNSEEN
  OPENED
  ANSWERED
  REVEALED
  SKIPPED
}

enum StudyQuestionResultStatus {
  CORRECT
  PARTIAL
  INCORRECT
  UNKNOWN
}

enum StudyQuestionDiagnosis {
  CONCEPT
  METHOD
  CALCULATION
  TIME_PRESSURE
}

enum StudyQuestionEvaluationMode {
  AUTO
  MANUAL
  SELF_ASSESSED
  UNGRADED
}

enum StudyQuestionReflection {
  MISSED
  HARD
  MEDIUM
  EASY
}

enum StudentMasteryBucket {
  NEW
  WATCH
  WEAK
  RECOVERING
  SOLID
}

enum StudyReviewQueueReasonType {
  MISSED
  HARD
  SKIPPED
  REVEALED
  FLAGGED
}

enum StudyReviewQueueStatus {
  OPEN
  DONE
  SNOOZED
  REMOVED
}

enum StudyReviewOutcome {
  CORRECT
  INCORRECT
}

enum TopicKind {
  UNIT
  TOPIC
  SUBTOPIC
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum ExamNodeSkillSource {
  TOPIC_DERIVED
  MANUAL_REVIEW
}

enum IngestionJobStatus {
  DRAFT
  QUEUED
  PROCESSING
  IN_REVIEW
  APPROVED
  PUBLISHED
  FAILED
}

enum SourceDocumentKind {
  EXAM
  CORRECTION
}

enum ExamVariantCode {
  SUJET_1
  SUJET_2
}

enum ExamNodeType {
  EXERCISE
  PART
  QUESTION
  SUBQUESTION
  CONTEXT
}

enum BlockRole {
  STEM
  PROMPT
  SOLUTION
  HINT
  RUBRIC
  META
}

enum BlockType {
  PARAGRAPH
  LATEX
  IMAGE
  CODE
  HEADING
  LIST
  TABLE
  GRAPH
  TREE
}

enum MediaType {
  IMAGE
  FILE
}

enum UserRole {
  USER
  ADMIN
  REVIEWER
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingProvider {
  CHARGILY
}

enum BillingCheckoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELED
  EXPIRED
}

enum BillingWebhookEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

model StreamFamily {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  slug        String?  @unique
  description String?  @db.Text
  pathways    Stream[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("stream_families")
}

model Stream {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  familyId            String                    @map("family_id") @db.Uuid
  code                String                    @unique
  name                String
  slug                String?                   @unique
  description         String?                   @db.Text
  isDefault           Boolean                   @default(false) @map("is_default")
  family              StreamFamily              @relation(fields: [familyId], references: [id], onDelete: Restrict)
  subjectMappings     StreamSubject[]
  curriculumMappings  SubjectCurriculumStream[]
  exams               Exam[]
  paperSourceMappings PaperSourceStream[]
  users               User[]
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  @@index([familyId])
  @@index([familyId, isDefault])
  @@map("streams")
}

model SubjectFamily {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique
  name        String
  slug        String?   @unique
  description String?   @db.Text
  subjects    Subject[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("subject_families")
}

model Subject {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  familyId       String              @map("family_id") @db.Uuid
  code           String              @unique
  name           String
  slug           String?             @unique
  description    String?             @db.Text
  isDefault      Boolean             @default(false) @map("is_default")
  family         SubjectFamily       @relation(fields: [familyId], references: [id], onDelete: Restrict)
  streamMappings StreamSubject[]
  exams          Exam[]              @relation("SubjectExams")
  papers         Paper[]             @relation("SubjectPapers")
  paperSources   PaperSource[]
  curricula      SubjectCurriculum[]
  topics         Topic[]
  skills         Skill[]
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([familyId])
  @@index([familyId, isDefault])
  @@map("subjects")
}

model SubjectCurriculum {
  id             String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId      String                    @map("subject_id") @db.Uuid
  code           String
  familyCode     String                    @default("legacy") @map("family_code")
  title          String
  validFromYear  Int                       @default(0) @map("valid_from_year")
  validToYear    Int?                      @map("valid_to_year")
  isActive       Boolean                   @default(true) @map("is_active")
  subject        Subject                   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  streamMappings SubjectCurriculumStream[]
  topics         Topic[]
  skills         Skill[]
  roadmaps       SubjectRoadmap[]
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  @@unique([subjectId, code])
  @@index([subjectId, isActive])
  @@index([subjectId, familyCode])
  @@index([subjectId, validFromYear, validToYear])
  @@map("subject_curricula")
}

model SubjectCurriculumStream {
  curriculumId String            @map("curriculum_id") @db.Uuid
  streamId     String            @map("stream_id") @db.Uuid
  createdAt    DateTime          @default(now()) @map("created_at")
  curriculum   SubjectCurriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  stream       Stream            @relation(fields: [streamId], references: [id], onDelete: Restrict)

  @@id([curriculumId, streamId])
  @@index([streamId])
  @@index([curriculumId])
  @@map("subject_curriculum_streams")
}

model StreamSubject {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  streamId      String   @map("stream_id") @db.Uuid
  subjectId     String   @map("subject_id") @db.Uuid
  coefficient   Int?
  isOptional    Boolean  @default(false) @map("is_optional")
  validFromYear Int      @default(0) @map("valid_from_year")
  validToYear   Int?     @map("valid_to_year")
  createdAt     DateTime @default(now()) @map("created_at")
  stream        Stream   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([streamId, subjectId, validFromYear])
  @@index([subjectId])
  @@index([streamId, validFromYear, validToYear])
  @@map("stream_subjects")
}

model PaperSource {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                    String              @unique
  provider                String
  year                    Int
  sessionType             SessionType         @map("session_type")
  subjectId               String              @map("subject_id") @db.Uuid
  familyCode              String              @map("family_code")
  sourceListingUrl        String?             @map("source_listing_url") @db.Text
  sourceExamPageUrl       String?             @map("source_exam_page_url") @db.Text
  sourceCorrectionPageUrl String?             @map("source_correction_page_url") @db.Text
  metadata                Json?
  subject                 Subject             @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  streamMappings          PaperSourceStream[]
  sourceDocuments         SourceDocument[]
  ingestionJobs           IngestionJob[]
  papers                  Paper[]
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  @@unique([year, subjectId, sessionType, familyCode])
  @@index([subjectId])
  @@index([year, subjectId, sessionType])
  @@map("paper_sources")
}

model PaperSourceStream {
  paperSourceId String      @map("paper_source_id") @db.Uuid
  streamId      String      @map("stream_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  paperSource   PaperSource @relation(fields: [paperSourceId], references: [id], onDelete: Cascade)
  stream        Stream      @relation(fields: [streamId], references: [id], onDelete: Restrict)

  @@id([paperSourceId, streamId])
  @@index([streamId])
  @@map("paper_source_streams")
}

model Paper {
  id                      String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperSourceId           String         @unique @map("paper_source_id") @db.Uuid
  year                    Int
  subjectId               String         @map("subject_id") @db.Uuid
  sessionType             SessionType    @map("session_type")
  familyCode              String         @map("family_code")
  durationMinutes         Int            @map("duration_minutes")
  officialSourceReference String?        @map("official_source_reference") @db.Text
  paperSource             PaperSource    @relation(fields: [paperSourceId], references: [id], onDelete: Restrict)
  subject                 Subject        @relation("SubjectPapers", fields: [subjectId], references: [id], onDelete: Restrict)
  offerings               Exam[]
  variants                ExamVariant[]
  ingestionJobs           IngestionJob[] @relation("IngestionJobPublishedPaper")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  @@unique([year, subjectId, sessionType, familyCode])
  @@index([year, subjectId, sessionType])
  @@map("papers")
}

model Exam {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year                  Int
  streamId              String                 @map("stream_id") @db.Uuid
  subjectId             String                 @map("subject_id") @db.Uuid
  sessionType           SessionType            @map("session_type")
  paperId               String                 @map("paper_id") @db.Uuid
  isPublished           Boolean                @default(false) @map("is_published")
  stream                Stream                 @relation(fields: [streamId], references: [id], onDelete: Restrict)
  subject               Subject                @relation("SubjectExams", fields: [subjectId], references: [id], onDelete: Restrict)
  paper                 Paper                  @relation(fields: [paperId], references: [id], onDelete: Restrict)
  ingestionJobs         IngestionJob[]         @relation("IngestionJobPublishedExam")
  studySessionExercises StudySessionExercise[]
  sourceStudySessions   StudySession[]         @relation("StudySessionSourceExam")
  activities            ExamActivity[]
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  @@unique([year, streamId, subjectId, sessionType])
  @@index([year, streamId, subjectId])
  @@index([paperId])
  @@map("exams")
}

model ExamVariant {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperId   String            @map("paper_id") @db.Uuid
  code      ExamVariantCode
  title     String?
  status    PublicationStatus @default(DRAFT)
  metadata  Json?
  paper     Paper             @relation(fields: [paperId], references: [id], onDelete: Cascade)
  nodes     ExamNode[]
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([paperId, code])
  @@index([paperId, status])
  @@map("exam_variants")
}

model ExamNode {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId                String                   @map("variant_id") @db.Uuid
  parentId                 String?                  @map("parent_id") @db.Uuid
  nodeType                 ExamNodeType             @map("node_type")
  orderIndex               Int                      @map("order_index")
  label                    String?
  maxPoints                Decimal?                 @map("max_points") @db.Decimal(6, 2)
  status                   PublicationStatus        @default(DRAFT)
  metadata                 Json?
  variant                  ExamVariant              @relation(fields: [variantId], references: [id], onDelete: Cascade)
  parent                   ExamNode?                @relation("ExamNodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children                 ExamNode[]               @relation("ExamNodeHierarchy")
  blocks                   ExamNodeBlock[]
  topicMappings            ExamNodeTopic[]
  skillMappings            ExamNodeSkill[]
  studySessionExercises    StudySessionExercise[]
  studySessionQuestions    StudySessionQuestion[]
  studentExerciseStates    StudentExerciseState[]
  reviewQuestionQueueItems StudentReviewQueueItem[] @relation("StudyReviewQueueQuestionNode")
  reviewExerciseQueueItems StudentReviewQueueItem[] @relation("StudyReviewQueueExerciseNode")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  @@unique([variantId, parentId, orderIndex])
  @@index([variantId, nodeType])
  @@index([parentId])
  @@map("exam_nodes")
}

model ExamNodeBlock {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId     String    @map("node_id") @db.Uuid
  role       BlockRole
  orderIndex Int       @map("order_index")
  blockType  BlockType @map("block_type")
  textValue  String?   @map("text_value") @db.Text
  mediaId    String?   @map("media_id") @db.Uuid
  data       Json?
  node       ExamNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  media      Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([nodeId, role, orderIndex])
  @@index([nodeId, role])
  @@index([mediaId])
  @@map("exam_node_blocks")
}

model Topic {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId      String               @map("subject_id") @db.Uuid
  curriculumId   String               @map("curriculum_id") @db.Uuid
  code           String
  name           String
  slug           String
  parentId       String?              @map("parent_id") @db.Uuid
  kind           TopicKind            @default(SUBTOPIC)
  depth          Int                  @default(0)
  path           String               @db.Text
  displayOrder   Int                  @default(0) @map("display_order")
  isSelectable   Boolean              @default(true) @map("is_selectable")
  studentLabel   String?              @map("student_label")
  subject        Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculum     SubjectCurriculum    @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  parent         Topic?               @relation("TopicHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Topic[]              @relation("TopicHierarchy")
  examNodeTopics ExamNodeTopic[]
  skillMappings  TopicSkill[]
  topicStats     UserTopicStats[]
  studentRollups StudentTopicRollup[]
  roadmapNodes   RoadmapNode[]
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@unique([curriculumId, code])
  @@unique([curriculumId, slug])
  @@unique([curriculumId, parentId, name])
  @@index([subjectId])
  @@index([curriculumId])
  @@index([curriculumId, displayOrder])
  @@index([curriculumId, path])
  @@index([parentId])
  @@map("topics")
}

model SubjectRoadmap {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curriculumId String            @map("curriculum_id") @db.Uuid
  code         String
  title        String
  description  String?           @db.Text
  version      Int               @default(1)
  isActive     Boolean           @default(true) @map("is_active")
  curriculum   SubjectCurriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  sections     RoadmapSection[]
  nodes        RoadmapNode[]
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@unique([curriculumId, code])
  @@index([curriculumId, isActive])
  @@map("subject_roadmaps")
}

model RoadmapSection {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roadmapId   String         @map("roadmap_id") @db.Uuid
  code        String
  title       String
  description String?        @db.Text
  orderIndex  Int            @map("order_index")
  roadmap     SubjectRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  nodes       RoadmapNode[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@unique([roadmapId, code])
  @@unique([roadmapId, orderIndex])
  @@index([roadmapId, orderIndex])
  @@map("roadmap_sections")
}

model RoadmapNode {
  id                               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roadmapId                        String          @map("roadmap_id") @db.Uuid
  sectionId                        String?         @map("section_id") @db.Uuid
  topicId                          String          @map("topic_id") @db.Uuid
  title                            String
  description                      String?         @db.Text
  orderIndex                       Int             @map("order_index")
  parentRoadmapNodeId              String?         @map("parent_roadmap_node_id") @db.Uuid
  recommendedPreviousRoadmapNodeId String?         @map("recommended_previous_roadmap_node_id") @db.Uuid
  estimatedSessions                Int?            @map("estimated_sessions")
  isOptional                       Boolean         @default(false) @map("is_optional")
  roadmap                          SubjectRoadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  section                          RoadmapSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  topic                            Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parent                           RoadmapNode?    @relation("RoadmapNodeHierarchy", fields: [parentRoadmapNodeId], references: [id], onDelete: SetNull)
  children                         RoadmapNode[]   @relation("RoadmapNodeHierarchy")
  recommendedPrevious              RoadmapNode?    @relation("RoadmapNodeRecommendation", fields: [recommendedPreviousRoadmapNodeId], references: [id], onDelete: SetNull)
  recommendedNext                  RoadmapNode[]   @relation("RoadmapNodeRecommendation")
  createdAt                        DateTime        @default(now()) @map("created_at")
  updatedAt                        DateTime        @updatedAt @map("updated_at")

  @@unique([roadmapId, topicId])
  @@unique([roadmapId, orderIndex])
  @@index([sectionId])
  @@index([topicId])
  @@index([parentRoadmapNodeId])
  @@index([recommendedPreviousRoadmapNodeId])
  @@map("roadmap_nodes")
}

model Skill {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId      String               @map("subject_id") @db.Uuid
  curriculumId   String               @map("curriculum_id") @db.Uuid
  code           String
  name           String
  slug           String
  description    String?              @db.Text
  displayOrder   Int                  @default(0) @map("display_order")
  isAssessable   Boolean              @default(true) @map("is_assessable")
  subject        Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculum     SubjectCurriculum    @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  topicMappings  TopicSkill[]
  nodeMappings   ExamNodeSkill[]
  studentRollups StudentSkillRollup[]
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@unique([curriculumId, code])
  @@unique([curriculumId, slug])
  @@index([subjectId])
  @@index([curriculumId])
  @@index([curriculumId, displayOrder])
  @@map("skills")
}

model TopicSkill {
  topicId   String  @map("topic_id") @db.Uuid
  skillId   String  @map("skill_id") @db.Uuid
  weight    Decimal @default(1) @db.Decimal(4, 2)
  isPrimary Boolean @default(false) @map("is_primary")
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([topicId, skillId])
  @@index([skillId])
  @@map("topic_skills")
}

model ExamNodeTopic {
  nodeId  String   @map("node_id") @db.Uuid
  topicId String   @map("topic_id") @db.Uuid
  node    ExamNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  topic   Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([nodeId, topicId])
  @@index([topicId])
  @@map("exam_node_topics")
}

model ExamNodeSkill {
  nodeId     String              @map("node_id") @db.Uuid
  skillId    String              @map("skill_id") @db.Uuid
  weight     Decimal             @default(1) @db.Decimal(4, 2)
  isPrimary  Boolean             @default(false) @map("is_primary")
  source     ExamNodeSkillSource @default(TOPIC_DERIVED)
  confidence Decimal?            @db.Decimal(4, 2)
  reviewedAt DateTime?           @map("reviewed_at")
  node       ExamNode            @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  skill      Skill               @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  @@id([nodeId, skillId])
  @@index([skillId])
  @@index([source])
  @@map("exam_node_skills")
}

model User {
  id                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkUserId        String?                  @unique @map("clerk_user_id")
  email              String                   @unique
  fullName           String?                  @map("full_name")
  role               UserRole                 @default(USER)
  subscriptionStatus SubscriptionStatus       @default(FREE) @map("subscription_status")
  subscriptionEndsAt DateTime?                @map("subscription_ends_at")
  streamId           String?                  @map("stream_id") @db.Uuid
  stream             Stream?                  @relation(fields: [streamId], references: [id], onDelete: SetNull)
  topicStats         UserTopicStats[]
  topicRollups       StudentTopicRollup[]
  skillRollups       StudentSkillRollup[]
  uploadedMedia      Media[]                  @relation("UserUploadedMedia")
  studySessions      StudySession[]
  examActivities     ExamActivity[]
  exerciseStates     StudentExerciseState[]
  reviewQueueItems   StudentReviewQueueItem[]
  billingCheckouts   BillingCheckout[]
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  @@index([streamId])
  @@index([subscriptionStatus, subscriptionEndsAt])
  @@map("users")
}

model BillingCheckout {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String                @map("user_id") @db.Uuid
  provider              BillingProvider
  planCode              String                @map("plan_code")
  currency              String
  amount                Int
  status                BillingCheckoutStatus @default(PENDING)
  locale                String
  providerCheckoutId    String?               @unique @map("provider_checkout_id")
  providerCustomerId    String?               @map("provider_customer_id")
  providerPaymentMethod String?               @map("provider_payment_method")
  providerInvoiceId     String?               @map("provider_invoice_id")
  providerLivemode      Boolean?              @map("provider_livemode")
  checkoutUrl           String?               @map("checkout_url") @db.Text
  successUrl            String                @map("success_url") @db.Text
  failureUrl            String                @map("failure_url") @db.Text
  webhookUrl            String                @map("webhook_url") @db.Text
  failureReason         String?               @map("failure_reason") @db.Text
  providerPayload       Json?                 @map("provider_payload")
  metadata              Json?
  accessStartsAt        DateTime?             @map("access_starts_at")
  accessEndsAt          DateTime?             @map("access_ends_at")
  paidAt                DateTime?             @map("paid_at")
  lastSyncedAt          DateTime?             @map("last_synced_at")
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEvents         BillingWebhookEvent[]
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
