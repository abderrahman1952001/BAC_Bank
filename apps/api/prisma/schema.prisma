generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionType {
  NORMAL
  MAKEUP
}

enum StudySessionStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum StudySessionFamily {
  DRILL
  SIMULATION
}

enum StudySessionKind {
  TOPIC_DRILL
  MIXED_DRILL
  WEAK_POINT_DRILL
  PAPER_SIMULATION
}

enum StudySessionResumeMode {
  SOLVE
  REVIEW
}

enum StudyQuestionAnswerState {
  UNSEEN
  OPENED
  ANSWERED
  REVEALED
  SKIPPED
}

enum StudyQuestionResultStatus {
  CORRECT
  PARTIAL
  INCORRECT
  UNKNOWN
}

enum StudyQuestionDiagnosis {
  CONCEPT
  METHOD
  CALCULATION
  TIME_PRESSURE
}

enum StudyQuestionEvaluationMode {
  AUTO
  MANUAL
  SELF_ASSESSED
  UNGRADED
}

enum StudyQuestionReflection {
  MISSED
  HARD
  MEDIUM
  EASY
}

enum StudentMasteryBucket {
  NEW
  WATCH
  WEAK
  RECOVERING
  SOLID
}

enum StudyReviewQueueReasonType {
  MISSED
  HARD
  SKIPPED
  REVEALED
  FLAGGED
}

enum StudyReviewQueueStatus {
  OPEN
  DONE
  SNOOZED
  REMOVED
}

enum StudyReviewOutcome {
  CORRECT
  INCORRECT
}

enum CurriculumNodeKind {
  FIELD
  UNIT
  TOPIC
  CONCEPT
  SKILL
  OPTIONAL_PORTAL
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}

enum CourseLessonStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum CourseStepKind {
  OBJECTIVE
  INTUITION
  FORMAL_RULE
  WORKED_EXAMPLE
  INTERACTION
  COMMON_TRAP
  BAC_LENS
  MICRO_QUIZ
  OPTIONAL_PORTAL
  SUMMARY
  CUSTOM
}

enum CourseLessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  NEEDS_REVIEW
}

enum ExamNodeSkillSource {
  TOPIC_DERIVED
  MANUAL_REVIEW
}

enum IngestionJobStatus {
  DRAFT
  QUEUED
  PROCESSING
  IN_REVIEW
  APPROVED
  PUBLISHED
  FAILED
}

enum SourceDocumentKind {
  EXAM
  CORRECTION
}

enum ExamVariantCode {
  SUJET_1
  SUJET_2
}

enum ExamNodeType {
  EXERCISE
  PART
  QUESTION
  SUBQUESTION
  CONTEXT
}

enum BlockRole {
  STEM
  PROMPT
  SOLUTION
  HINT
  RUBRIC
  META
}

enum BlockType {
  PARAGRAPH
  LATEX
  IMAGE
  CODE
  HEADING
  LIST
  TABLE
  GRAPH
  TREE
}

enum MediaType {
  IMAGE
  FILE
}

enum UserRole {
  USER
  ADMIN
  REVIEWER
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingProvider {
  CHARGILY
}

enum BillingCheckoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELED
  EXPIRED
}

enum BillingWebhookEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

model StreamFamily {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String   @unique
  name        String
  slug        String?  @unique
  description String?  @db.Text
  pathways    Stream[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("stream_families")
}

model Stream {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  familyId            String              @map("family_id") @db.Uuid
  code                String              @unique
  name                String
  slug                String?             @unique
  description         String?             @db.Text
  isDefault           Boolean             @default(false) @map("is_default")
  family              StreamFamily        @relation(fields: [familyId], references: [id], onDelete: Restrict)
  subjectOfferings    SubjectOffering[]
  exams               Exam[]
  paperSourceMappings PaperSourceStream[]
  users               User[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([familyId])
  @@index([familyId, isDefault])
  @@map("streams")
}

model SubjectFamily {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique
  name        String
  slug        String?   @unique
  description String?   @db.Text
  subjects    Subject[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("subject_families")
}

model Subject {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  familyId         String            @map("family_id") @db.Uuid
  code             String            @unique
  name             String
  slug             String?           @unique
  description      String?           @db.Text
  isDefault        Boolean           @default(false) @map("is_default")
  family           SubjectFamily     @relation(fields: [familyId], references: [id], onDelete: Restrict)
  subjectOfferings SubjectOffering[]
  exams            Exam[]            @relation("SubjectExams")
  papers           Paper[]           @relation("SubjectPapers")
  paperSources     PaperSource[]
  curricula        Curriculum[]
  curriculumNodes  CurriculumNode[]
  skills           Skill[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([familyId])
  @@index([familyId, isDefault])
  @@map("subjects")
}

model Curriculum {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId        String            @map("subject_id") @db.Uuid
  code             String
  familyCode       String            @default("legacy") @map("family_code")
  title            String
  validFromYear    Int               @default(0) @map("valid_from_year")
  validToYear      Int?              @map("valid_to_year")
  isActive         Boolean           @default(true) @map("is_active")
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectOfferings SubjectOffering[]
  curriculumNodes  CurriculumNode[]
  skills           Skill[]
  courseLessons    CourseLesson[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@unique([subjectId, code])
  @@index([subjectId, isActive])
  @@index([subjectId, familyCode])
  @@index([subjectId, validFromYear, validToYear])
  @@map("curricula")
}

model SubjectOffering {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  streamId      String     @map("stream_id") @db.Uuid
  subjectId     String     @map("subject_id") @db.Uuid
  curriculumId  String     @map("curriculum_id") @db.Uuid
  coefficient   Int?
  isOptional    Boolean    @default(false) @map("is_optional")
  validFromYear Int        @default(0) @map("valid_from_year")
  validToYear   Int?       @map("valid_to_year")
  createdAt     DateTime   @default(now()) @map("created_at")
  stream        Stream     @relation(fields: [streamId], references: [id], onDelete: Cascade)
  subject       Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculum    Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Restrict)

  @@unique([streamId, subjectId, validFromYear])
  @@index([subjectId])
  @@index([curriculumId])
  @@index([streamId, validFromYear, validToYear])
  @@map("subject_offerings")
}

model PaperSource {
  id                      String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                    String              @unique
  provider                String
  year                    Int
  sessionType             SessionType         @map("session_type")
  subjectId               String              @map("subject_id") @db.Uuid
  familyCode              String              @map("family_code")
  sourceListingUrl        String?             @map("source_listing_url") @db.Text
  sourceExamPageUrl       String?             @map("source_exam_page_url") @db.Text
  sourceCorrectionPageUrl String?             @map("source_correction_page_url") @db.Text
  metadata                Json?
  subject                 Subject             @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  streamMappings          PaperSourceStream[]
  sourceDocuments         SourceDocument[]
  ingestionJobs           IngestionJob[]
  papers                  Paper[]
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  @@unique([year, subjectId, sessionType, familyCode])
  @@index([subjectId])
  @@index([year, subjectId, sessionType])
  @@map("paper_sources")
}

model PaperSourceStream {
  paperSourceId String      @map("paper_source_id") @db.Uuid
  streamId      String      @map("stream_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  paperSource   PaperSource @relation(fields: [paperSourceId], references: [id], onDelete: Cascade)
  stream        Stream      @relation(fields: [streamId], references: [id], onDelete: Restrict)

  @@id([paperSourceId, streamId])
  @@index([streamId])
  @@map("paper_source_streams")
}

model Paper {
  id                      String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperSourceId           String         @unique @map("paper_source_id") @db.Uuid
  year                    Int
  subjectId               String         @map("subject_id") @db.Uuid
  sessionType             SessionType    @map("session_type")
  familyCode              String         @map("family_code")
  durationMinutes         Int            @map("duration_minutes")
  officialSourceReference String?        @map("official_source_reference") @db.Text
  paperSource             PaperSource    @relation(fields: [paperSourceId], references: [id], onDelete: Restrict)
  subject                 Subject        @relation("SubjectPapers", fields: [subjectId], references: [id], onDelete: Restrict)
  offerings               Exam[]
  variants                ExamVariant[]
  ingestionJobs           IngestionJob[] @relation("IngestionJobPublishedPaper")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  @@unique([year, subjectId, sessionType, familyCode])
  @@index([year, subjectId, sessionType])
  @@map("papers")
}

model Exam {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year                  Int
  streamId              String                 @map("stream_id") @db.Uuid
  subjectId             String                 @map("subject_id") @db.Uuid
  sessionType           SessionType            @map("session_type")
  paperId               String                 @map("paper_id") @db.Uuid
  isPublished           Boolean                @default(false) @map("is_published")
  stream                Stream                 @relation(fields: [streamId], references: [id], onDelete: Restrict)
  subject               Subject                @relation("SubjectExams", fields: [subjectId], references: [id], onDelete: Restrict)
  paper                 Paper                  @relation(fields: [paperId], references: [id], onDelete: Restrict)
  ingestionJobs         IngestionJob[]         @relation("IngestionJobPublishedExam")
  studySessionExercises StudySessionExercise[]
  sourceStudySessions   StudySession[]         @relation("StudySessionSourceExam")
  activities            ExamActivity[]
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  @@unique([year, streamId, subjectId, sessionType])
  @@index([year, streamId, subjectId])
  @@index([paperId])
  @@map("exams")
}

model ExamVariant {
  id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paperId   String            @map("paper_id") @db.Uuid
  code      ExamVariantCode
  title     String?
  status    PublicationStatus @default(DRAFT)
  metadata  Json?
  paper     Paper             @relation(fields: [paperId], references: [id], onDelete: Cascade)
  nodes     ExamNode[]
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@unique([paperId, code])
  @@index([paperId, status])
  @@map("exam_variants")
}

model ExamNode {
  id                       String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId                String                   @map("variant_id") @db.Uuid
  parentId                 String?                  @map("parent_id") @db.Uuid
  nodeType                 ExamNodeType             @map("node_type")
  orderIndex               Int                      @map("order_index")
  label                    String?
  maxPoints                Decimal?                 @map("max_points") @db.Decimal(6, 2)
  status                   PublicationStatus        @default(DRAFT)
  metadata                 Json?
  variant                  ExamVariant              @relation(fields: [variantId], references: [id], onDelete: Cascade)
  parent                   ExamNode?                @relation("ExamNodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children                 ExamNode[]               @relation("ExamNodeHierarchy")
  blocks                   ExamNodeBlock[]
  curriculumNodeMappings   ExamNodeCurriculumNode[]
  skillMappings            ExamNodeSkill[]
  studySessionExercises    StudySessionExercise[]
  studySessionQuestions    StudySessionQuestion[]
  studentExerciseStates    StudentExerciseState[]
  reviewQuestionQueueItems StudentReviewQueueItem[] @relation("StudyReviewQueueQuestionNode")
  reviewExerciseQueueItems StudentReviewQueueItem[] @relation("StudyReviewQueueExerciseNode")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  @@unique([variantId, parentId, orderIndex])
  @@index([variantId, nodeType])
  @@index([parentId])
  @@map("exam_nodes")
}

model ExamNodeBlock {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nodeId     String    @map("node_id") @db.Uuid
  role       BlockRole
  orderIndex Int       @map("order_index")
  blockType  BlockType @map("block_type")
  textValue  String?   @map("text_value") @db.Text
  mediaId    String?   @map("media_id") @db.Uuid
  data       Json?
  node       ExamNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  media      Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([nodeId, role, orderIndex])
  @@index([nodeId, role])
  @@index([mediaId])
  @@map("exam_node_blocks")
}

model CurriculumNode {
  id               String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId        String                        @map("subject_id") @db.Uuid
  curriculumId     String                        @map("curriculum_id") @db.Uuid
  code             String
  name             String
  slug             String
  parentId         String?                       @map("parent_id") @db.Uuid
  kind             CurriculumNodeKind            @default(CONCEPT)
  depth            Int                           @default(0)
  path             String                        @db.Text
  displayOrder     Int                           @default(0) @map("display_order")
  isSelectable     Boolean                       @default(true) @map("is_selectable")
  studentLabel     String?                       @map("student_label")
  metadata         Json?
  subject          Subject                       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculum       Curriculum                    @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  parent           CurriculumNode?               @relation("CurriculumNodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         CurriculumNode[]              @relation("CurriculumNodeHierarchy")
  examNodeMappings ExamNodeCurriculumNode[]
  skillMappings    CurriculumNodeSkill[]
  nodeStats        UserCurriculumNodeStats[]
  studentRollups   StudentCurriculumNodeRollup[]
  courseLessons    CourseLesson[]
  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime                      @updatedAt @map("updated_at")

  @@unique([curriculumId, code])
  @@unique([curriculumId, slug])
  @@unique([curriculumId, parentId, name])
  @@index([subjectId])
  @@index([curriculumId])
  @@index([curriculumId, displayOrder])
  @@index([curriculumId, path])
  @@index([parentId])
  @@map("curriculum_nodes")
}

model Skill {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subjectId              String                @map("subject_id") @db.Uuid
  curriculumId           String                @map("curriculum_id") @db.Uuid
  code                   String
  name                   String
  slug                   String
  description            String?               @db.Text
  displayOrder           Int                   @default(0) @map("display_order")
  isAssessable           Boolean               @default(true) @map("is_assessable")
  subject                Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  curriculum             Curriculum            @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  curriculumNodeMappings CurriculumNodeSkill[]
  nodeMappings           ExamNodeSkill[]
  studentRollups         StudentSkillRollup[]
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  @@unique([curriculumId, code])
  @@unique([curriculumId, slug])
  @@index([subjectId])
  @@index([curriculumId])
  @@index([curriculumId, displayOrder])
  @@map("skills")
}

model CurriculumNodeSkill {
  curriculumNodeId String         @map("curriculum_node_id") @db.Uuid
  skillId          String         @map("skill_id") @db.Uuid
  weight           Decimal        @default(1) @db.Decimal(4, 2)
  isPrimary        Boolean        @default(false) @map("is_primary")
  curriculumNode   CurriculumNode @relation(fields: [curriculumNodeId], references: [id], onDelete: Cascade)
  skill            Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([curriculumNodeId, skillId])
  @@index([skillId])
  @@map("curriculum_node_skills")
}

model ExamNodeCurriculumNode {
  nodeId           String         @map("node_id") @db.Uuid
  curriculumNodeId String         @map("curriculum_node_id") @db.Uuid
  node             ExamNode       @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  curriculumNode   CurriculumNode @relation(fields: [curriculumNodeId], references: [id], onDelete: Cascade)

  @@id([nodeId, curriculumNodeId])
  @@index([curriculumNodeId])
  @@map("exam_node_curriculum_nodes")
}

model ExamNodeSkill {
  nodeId     String              @map("node_id") @db.Uuid
  skillId    String              @map("skill_id") @db.Uuid
  weight     Decimal             @default(1) @db.Decimal(4, 2)
  isPrimary  Boolean             @default(false) @map("is_primary")
  source     ExamNodeSkillSource @default(TOPIC_DERIVED)
  confidence Decimal?            @db.Decimal(4, 2)
  reviewedAt DateTime?           @map("reviewed_at")
  node       ExamNode            @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  skill      Skill               @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  @@id([nodeId, skillId])
  @@index([skillId])
  @@index([source])
  @@map("exam_node_skills")
}

model CourseLesson {
  id                 String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  curriculumId       String                        @map("curriculum_id") @db.Uuid
  curriculumNodeId   String                        @map("curriculum_node_id") @db.Uuid
  code               String
  slug               String
  title              String
  description        String?                       @db.Text
  language           String                        @default("ar-DZ")
  status             CourseLessonStatus            @default(DRAFT)
  version            Int                           @default(1)
  estimatedMinutes   Int?                          @map("estimated_minutes")
  sourceMarkdownPath String?                       @map("source_markdown_path") @db.Text
  contentHash        String?                       @map("content_hash")
  metadata           Json?
  curriculum         Curriculum                    @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  curriculumNode     CurriculumNode                @relation(fields: [curriculumNodeId], references: [id], onDelete: Cascade)
  steps              CourseStep[]
  visualAssets       CourseVisualAsset[]
  quizzes            CourseQuiz[]
  depthPortals       CourseDepthPortal[]
  studentProgress    StudentCourseLessonProgress[]
  createdAt          DateTime                      @default(now()) @map("created_at")
  updatedAt          DateTime                      @updatedAt @map("updated_at")

  @@unique([curriculumId, code])
  @@index([curriculumId, status])
  @@index([curriculumNodeId, status])
  @@map("course_lessons")
}

model CourseStep {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId     String              @map("lesson_id") @db.Uuid
  kind         CourseStepKind
  title        String?
  body         String              @db.Text
  orderIndex   Int                 @map("order_index")
  data         Json?
  lesson       CourseLesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  visualAssets CourseVisualAsset[]
  quizzes      CourseQuiz[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@unique([lessonId, orderIndex])
  @@index([lessonId, kind])
  @@map("course_steps")
}

model CourseVisualAsset {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId   String       @map("lesson_id") @db.Uuid
  stepId     String?      @map("step_id") @db.Uuid
  code       String
  title      String?
  kind       String
  url        String?      @db.Text
  prompt     String?      @db.Text
  orderIndex Int          @default(0) @map("order_index")
  metadata   Json?
  lesson     CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  step       CourseStep?  @relation(fields: [stepId], references: [id], onDelete: SetNull)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@unique([lessonId, code])
  @@index([lessonId, orderIndex])
  @@index([stepId])
  @@map("course_visual_assets")
}

model CourseDepthPortal {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId   String       @map("lesson_id") @db.Uuid
  code       String
  title      String
  body       String       @db.Text
  orderIndex Int          @default(0) @map("order_index")
  metadata   Json?
  lesson     CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  @@unique([lessonId, code])
  @@index([lessonId, orderIndex])
  @@map("course_depth_portals")
}

model CourseQuiz {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId    String             @map("lesson_id") @db.Uuid
  stepId      String?            @map("step_id") @db.Uuid
  code        String
  prompt      String             @db.Text
  explanation String?            @db.Text
  orderIndex  Int                @default(0) @map("order_index")
  metadata    Json?
  lesson      CourseLesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  step        CourseStep?        @relation(fields: [stepId], references: [id], onDelete: SetNull)
  options     CourseQuizOption[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@unique([lessonId, code])
  @@index([lessonId, orderIndex])
  @@index([stepId])
  @@map("course_quizzes")
}

model CourseQuizOption {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId     String     @map("quiz_id") @db.Uuid
  orderIndex Int        @map("order_index")
  text       String     @db.Text
  isCorrect  Boolean    @default(false) @map("is_correct")
  feedback   String?    @db.Text
  quiz       CourseQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@unique([quizId, orderIndex])
  @@index([quizId, isCorrect])
  @@map("course_quiz_options")
}

model StudentCourseLessonProgress {
  userId          String                     @map("user_id") @db.Uuid
  lessonId        String                     @map("lesson_id") @db.Uuid
  status          CourseLessonProgressStatus @default(NOT_STARTED)
  progressPercent Int                        @default(0) @map("progress_percent")
