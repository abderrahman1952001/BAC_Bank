              "solution_blocks": [
                {
                  "type": "paragraph",
                  "text": "$P_A(B)=\\frac{P(A\\cap B)}{P(A)}=\\frac{1}{7}$\n$P(C)=1-P(B)=\\frac{109}{165}$"
                }
